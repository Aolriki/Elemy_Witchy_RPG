  m_Script: {fileID: 11500000, guid: 32e28932c8fba0c41baaa8b8012e6f7d, type: 3}
  m_Name: Little_Talker 2
  m_EditorClassIdentifier: 
  sentences:
  - talker: 2
    sentenceText: "Voc\xEA n\xE3o m\xE1gica, mas bastante esfor\xE7o! Por qu\xEA?"
    sentenceAction: {fileID: 0}
  - talker: 1
    sentenceText: "Que susto! Voc\xEA de novo?"
    sentenceAction: {fileID: 0}
  - talker: 1
    sentenceText: "Eu to tentando ser uma bruxa, mas\u2026"
    sentenceAction: {fileID: 0}
  - talker: 2
    sentenceText: "Voc\xEA ser diferente. Nunca vi homenzinho alto sem magico nenhum."
    sentenceAction: {fileID: 0}
  - talker: 1
    sentenceText: "Grrh! Eu sei! E-Eu\u2026 Eu j\xE1 entendi\u2026 Mesmo que eu tente,
      n\xE3o consigo usar magia."
    sentenceAction: {fileID: 0}
  - talker: 2
    sentenceText: Elemy sempre amigo de quem ajuda. Derrubar corpo Selvagem, Elemy
      Puro agradece!
    sentenceAction: {fileID: 0}
  - talker: 1
    sentenceText: (... Do que ele ta falando?)
    sentenceAction: {fileID: 0}
  responses: []

  sentences:
  - talker: 1
    sentenceText: "Ei! Voc\xEA, muito obrigada por antes!"
    sentenceAction: {fileID: 0}
  - talker: 2
    sentenceText: "N\xE3o tem de que, Pequeno Falante sempre gosta de ajudar homemzinho
      alto."
    sentenceAction: {fileID: 0}
  - talker: 1
    sentenceText: Pequeno Falante? Hahaha, quem te deu esse apelido?
    sentenceAction: {fileID: 0}
  - talker: 2
    sentenceText: "N\xE3o apelido, nome. Mestre dos livros me ensinar a falar, ent\xE3o,
      nome!"
    sentenceAction: {fileID: 0}
  - talker: 1
    sentenceText: "Mestre dos livros? Ah! Voc\xEA viu os outros membros da caravana?
      Eu encontrei um deles!"
    sentenceAction: {fileID: 0}
  - talker: 2
    sentenceText: Caminho levar para o fim da jornada por agora. Obrigado por ter
      jogado! <3
    sentenceAction: {fileID: 0}

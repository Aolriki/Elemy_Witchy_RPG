  m_Name: Sign 1
  m_EditorClassIdentifier: 
  sentences:
  - talker: 5
    sentenceText: "\"J\xE1 ouviu falar no aprendizado em combate?\""
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: '"Vai precisar disso se quiser ficar vivo!"'
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: "\"Ent\xE3o fique atento aos detalhes, vai que voc\xEA acaba pegando
      algum 'insight' aqui ou ali.\""
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: '"Se sentir que pescou alguma coisa, abra algum livro e anote!
      (Pause), talvez de pra melhorar em alguma coisa!"'
    sentenceAction: {fileID: 0}
  responses: []

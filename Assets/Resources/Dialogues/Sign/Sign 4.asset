  sentences:
  - talker: 5
    sentenceText: '"Se alguem estiver com dificuldades pra subir por aqui..."'
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: "\"Recomendo procurar algo que possa ajudar l\xE1 pela esquerda,
      talvez tenha uma caixa pra usar de apoio?\""
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: "\"Sempre tem gente passando por l\xE1 ultimamente, quem sabe o
      que se vai encontrar.\""
    sentenceAction: {fileID: 0}

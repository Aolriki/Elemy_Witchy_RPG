  m_Script: {fileID: 11500000, guid: 32e28932c8fba0c41baaa8b8012e6f7d, type: 3}
  m_Name: Sign 3
  m_EditorClassIdentifier: 
  sentences:
  - talker: 5
    sentenceText: '" - Notas do rastreador: - "'
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: "\"Eu fui dar uma espiadinha por aqui, e vi que \xE0 esquerda,
      o caminho fica bem perigoso.\""
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: '"Mas talvez, se houver muitos Elemys Selvagens, pode ser que tenha
      alguma recompensa valiosa."'
    sentenceAction: {fileID: 0}
  - talker: 5
    sentenceText: '"De qualquer forma, tem outro caminho, ali por baixo! Caso alguem
      queira tomar mais cuidado!"'
    sentenceAction: {fileID: 0}
  responses: []
